{
  "name": "@tcg-cards/db",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db.ts",
    "./schema/local/hearthstone": "./src/schema/local/hearthstone/index.ts",
    "./schema/local/hearthstone/*": "./src/schema/local/hearthstone/*.ts",
    "./schema/local/magic": "./src/schema/local/magic/index.ts",
    "./schema/local/magic/*": "./src/schema/local/magic/*.ts",
    "./schema/remote/auth": "./src/schema/remote/auth.ts",
    "./schema/remote/publish": "./src/schema/remote/publish.ts",
    "./schema/remote/hearthstone": "./src/schema/remote/hearthstone/index.ts",
    "./schema/remote/hearthstone/*": "./src/schema/remote/hearthstone/*.ts",
    "./schema/remote/magic": "./src/schema/remote/magic/index.ts",
    "./schema/remote/magic/*": "./src/schema/remote/magic/*.ts",
    "./schema/shared/hearthstone": "./src/schema/shared/hearthstone/index.ts",
    "./schema/shared/hearthstone/*": "./src/schema/shared/hearthstone/*.ts",
    "./schema/shared/magic": "./src/schema/shared/magic/index.ts",
    "./schema/shared/magic/*": "./src/schema/shared/magic/*.ts"
  },
  "scripts": {
    "build": "echo No build needed",
    "db:generate:local": "drizzle-kit generate --config=drizzle.local.config.ts",
    "db:generate:remote": "drizzle-kit generate --config=drizzle.remote.config.ts",
    "db:migrate:local:dev": "bun --env-file=.env.local-dev ./node_modules/drizzle-kit/bin.cjs migrate --config=drizzle.local.config.ts",
    "db:migrate:remote:dev": "bun --env-file=.env.remote-dev ./node_modules/drizzle-kit/bin.cjs migrate --config=drizzle.remote.config.ts",
    "db:migrate:remote:prod": "bun --env-file=.env.remote-prod ./node_modules/drizzle-kit/bin.cjs migrate --config=drizzle.remote.config.ts",
    "db:push:local:dev": "bun --env-file=.env.local-dev ./node_modules/drizzle-kit/bin.cjs push --config=drizzle.local.config.ts",
    "db:push:remote:dev": "bun --env-file=.env.remote-dev ./node_modules/drizzle-kit/bin.cjs push --config=drizzle.remote.config.ts",
    "db:studio:local:dev": "bun --env-file=.env.local-dev ./node_modules/drizzle-kit/bin.cjs studio --config=drizzle.local.config.ts",
    "db:check:local": "drizzle-kit check --config=drizzle.local.config.ts",
    "db:check:remote": "drizzle-kit check --config=drizzle.remote.config.ts",
    "db:up:remote:prod": "bun --env-file=.env.remote-prod ./node_modules/drizzle-kit/bin.cjs up --config=drizzle.remote.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tcg-cards/model": "workspace:*",
    "@tcg-cards/shared": "workspace:*",
    "drizzle-orm": "^1.0.0-beta.22",
    "eslint-config-custom": "workspace:*",
    "lodash-es": "^4.17.23",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/lodash-es": "^4.17.12",
    "drizzle-kit": "^1.0.0-beta.22",
    "eslint": "^10.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
