{
  "name": "@tcg-cards/db",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db.ts",
    "./schema/auth": "./src/schema/auth.ts",
    "./schema/hearthstone": "./src/schema/hearthstone/index.ts",
    "./schema/magic": "./src/schema/magic/index.ts"
  },
  "scripts": {
    "build": "echo No build needed",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.production ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "bun --env-file=.env.development ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "bun --env-file=.env.development ./node_modules/drizzle-kit/bin.cjs studio",
    "db:check": "drizzle-kit check",
    "db:up": "bun --env-file=.env.production ./node_modules/drizzle-kit/bin.cjs up",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tcg-cards/model": "workspace:*",
    "@tcg-cards/shared": "workspace:*",
    "drizzle-orm": "^1.0.0-beta.22",
    "eslint-config-custom": "workspace:*",
    "lodash-es": "^4.17.23",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/lodash-es": "^4.17.12",
    "drizzle-kit": "^1.0.0-beta.22",
    "eslint": "^10.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
