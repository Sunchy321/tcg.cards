{
  "name": "tcg-cards",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "postinstall": "turbo run postinstall",
    "gen": "sh -c 'turbo gen new-site --args \"$1\" && bun install' sh"
  },
  "devDependencies": {
    "@turbo/gen": "^2.8.12",
    "prettier": "^3.2.5",
    "turbo": "^2.6.1"
  },
  "packageManager": "bun@1.3.10"
}
