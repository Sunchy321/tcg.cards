{
  "name": "tcg-cards",
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^1.0.0-beta.22"
  },
  "devDependencies": {
    "@turbo/gen": "^2.8.12",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "prettier": "^3.2.5",
    "turbo": "^2.6.1"
  },
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint typecheck build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "postinstall": "turbo run postinstall",
    "typecheck": "turbo run typecheck",
    "gen": "sh -c 'turbo gen new-site --args \"$1\" && bun install' sh",
    "webp:variants": "bun scripts/generate-webp-variants.ts",
    "webp:evaluate": "bun scripts/evaluate-webp-variants.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
