# Public URL used by Better Auth when running outside the browser.
BETTER_AUTH_URL=http://localhost:2999

# Secret used by Better Auth. Use a long random value in real environments.
BETTER_AUTH_SECRET=change-me

# Optional public base URL for already-published data files.
DATA_PUBLIC_URL=https://data.example.com

# S3-compatible endpoint and credentials for private data access.
DATA_ENDPOINT=https://example.r2.cloudflarestorage.com
DATA_BUCKET_NAME=data
DATA_ACCESS_KEY_ID=change-me
DATA_SECRET_ACCESS_KEY=change-me
