{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tcg-cards-console-desktop",
  "version": "0.1.0",
  "identifier": "cards.tcg.console-desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "label": "login",
        "title": "Sign In - TCG Cards Console",
        "width": 420,
        "height": 340,
        "resizable": false,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
