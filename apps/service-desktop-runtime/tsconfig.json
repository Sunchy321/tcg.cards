{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "#model/*": ["../../packages/model/src/*"],
      "#task/*": ["./src/lib/task/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "node"]
  },
  "include": ["src/**/*"]
}
